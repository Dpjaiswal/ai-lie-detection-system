# ==============================================================
# AI-Powered Lie Detection System — Environment Variables
# Copy this file to .env and fill in your values
# ==============================================================

# ─── Application ──────────────────────────────────────────────
APP_NAME="AI Lie Detection System"
APP_VERSION="1.0.0"
APP_ENV=development  # development | staging | production
DEBUG=true
SECRET_KEY=your-very-secret-key-change-this-in-production

# ─── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# ─── Model Paths ──────────────────────────────────────────────
NLP_MODEL_PATH=models/nlp/best_model
AUDIO_MODEL_PATH=models/audio/best_model
FUSION_MODEL_PATH=models/fusion/best_model
TOKENIZER_PATH=models/nlp/tokenizer

# ─── HuggingFace ──────────────────────────────────────────────
HF_MODEL_NAME=roberta-base
HF_CACHE_DIR=.cache/huggingface
HF_TOKEN=your-huggingface-token

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./lie_detection.db
# DATABASE_URL=postgresql://user:password@localhost:5432/liedetect

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=lie-detection

# ─── Weights & Biases ─────────────────────────────────────────
# (Not needed now — uncomment when you want to log experiments to W&B)
# WANDB_API_KEY=your-wandb-api-key
# WANDB_PROJECT=lie-detection-system
# WANDB_ENTITY=your-entity

# ─── AWS ──────────────────────────────────────────────────────
# (Not needed now — uncomment only for cloud model storage / ECS deployment)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=lie-detection-models

# ─── GCP ──────────────────────────────────────────────────────
# (Not needed now — uncomment only for GCS model storage)
# GCP_PROJECT_ID=your-gcp-project
# GCP_REGION=us-central1
# GCS_BUCKET_NAME=lie-detection-models

# ─── Azure ────────────────────────────────────────────────────
# (Not needed now — uncomment only for Azure Blob storage)
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=lie-detection-rg
# AZURE_STORAGE_ACCOUNT=liedetection

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | text
LOG_FILE=logs/app.log

# ─── Audio ────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=22050
AUDIO_MAX_DURATION=60
AUDIO_UPLOAD_DIR=data/audio/uploads

# ─── Security ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=60
